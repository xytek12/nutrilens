{
  "expo": {
    "name": "NutriLens",
    "slug": "nutrilens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nutrilens",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050D2D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.galshemtov.nutrilens",
      "infoPlist": {
        "NSCameraUsageDescription": "NutriLens uses your camera to analyze your meals and count calories automatically.",
        "NSPhotoLibraryUsageDescription": "NutriLens can analyze photos from your library to count meal calories."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050D2D"
      },
      "package": "com.galshemtov.nutrilens",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "NutriLens needs photo access to analyze your meals.",
          "cameraPermission": "NutriLens needs camera access to photograph your meals."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
