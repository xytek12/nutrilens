# ============================================
# NUTRILENS — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# Supabase (get from supabase.com → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (only used in scripts, NEVER in the app)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Gemini API (get from aistudio.google.com)
GEMINI_API_KEY=AIzaSy...

# RevenueCat (for subscriptions — leave empty for now)
REVENUECAT_API_KEY_ANDROID=
REVENUECAT_API_KEY_IOS=
